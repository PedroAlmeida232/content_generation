  "item": [
    {
      "name": "Auth Service",
      "description": "Requests do auth-service.",
      "item": [
        {
          "name": "Infra",
          "description": "Endpoints de infraestrutura, liveness e verificacao basica do servico.",
          "item": [
            {
              "name": "GET /health",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{authServiceBaseUrl}}/health",
                  "host": [
                    "{{authServiceBaseUrl}}"
                  ],
                  "path": [
                    "health"
                  ]
                },
                "description": "Valida que o auth-service esta no ar e responde sem autenticacao."
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {",
                      "    pm.response.to.have.status(200);",
                      "});",
                      "",
                      "pm.test(\"Response time is below 1000ms\", function () {",
                      "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                      "});",
                      "",
                      "pm.test(\"Response body has status ok\", function () {",
                      "    const json = pm.response.json();",
                      "    pm.expect(json.status).to.eql(\"ok\");",
                      "});",
                      "",
                      "pm.test(\"Content-Type is JSON\", function () {",
                      "    pm.response.to.have.header(\"Content-Type\");",
                      "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                      "});"
                    ]
                  }
                }
              ]
            }
          ]
        },
